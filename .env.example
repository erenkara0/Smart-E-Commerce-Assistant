# ==================================================
# Smart E-Commerce Assistant - Environment Template
# ==================================================
# This file defines required environment variables for local development.
# Do not place real secrets in this file.
# Copy this file as ".env" and fill real values locally.

# ==================================================
# Application
# ==================================================
APP_NAME=Smart E-Commerce Assistant
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

# ==================================================
# Backend / FastAPI
# ==================================================
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ==================================================
# Frontend / Next.js
# ==================================================
NEXT_PUBLIC_APP_NAME=Smart E-Commerce Assistant
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ==================================================
# OpenAI / LLM
# ==================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==================================================
# RAG Settings
# ==================================================
RETRIEVAL_TOP_K=4
RETRIEVAL_SCORE_THRESHOLD=0.70
RAG_MAX_CONTEXT_CHARS=4000
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ==================================================
# Vector Store / ChromaDB
# ==================================================
VECTOR_STORE_PROVIDER=in_memory
CHROMA_DB_PATH=./backend/storage/chroma
CHROMA_COLLECTION_NAME=store_knowledge_base

# ==================================================
# Database / SQLite
# ==================================================
SQLITE_DB_PATH=./backend/storage/app.db

# ==================================================
# Session / Memory
# ==================================================
SESSION_MEMORY_LIMIT=5
SESSION_TTL_DAYS=30

# ==================================================
# LangSmith / Observability
# ==================================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=smart-e-commerce-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ==================================================
# API Documentation / Scalar
# ==================================================
API_DOCS_TITLE=Smart E-Commerce Assistant API
API_DOCS_VERSION=v1
SCALAR_ENABLED=true